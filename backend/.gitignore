# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── uv ────────────────────────────────────────────────────────────────────────
.uv/

# ── Environment variables — NEVER commit these ────────────────────────────────
.env
.env.*
!.env.example

# ── dotenv local variants ────────────────────────────────────────────────────
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Firebase service account keys — CRITICAL: never commit ───────────────────
*service_account*.json
*firebase-adminsdk*.json
*credentials*.json
serviceAccountKey.json

# ── Alembic ───────────────────────────────────────────────────────────────────
# Keep migration files — they are part of source control
# Only ignore autogenerated cache
alembic/__pycache__/

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.pytype/
.pyre/

# ── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Uploads / temp files ──────────────────────────────────────────────────────
uploads/
tmp/
temp/

# ── pyenv ─────────────────────────────────────────────────────────────────────
.python-version