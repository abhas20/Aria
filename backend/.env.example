# ─────────────────────────────────────────────
# Aria Backend — Environment Variables
# ─────────────────────────────────────────────

# Application
APP_ENV=development                          # development | production
SECRET_KEY=change-me-in-production           # random 32-byte hex string

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/aria

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
# Path to the downloaded service account JSON key file
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_KEY_JSON=paste-the-json

# Gemini AI (Google)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Sarvam AI — primary STT/TTS for Hindi
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_API_BASE_URL=https://api.sarvam.ai

# Google Cloud — fallback STT/TTS
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
# Path to the GCP service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# Cloudinary — image and audio storage
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# CORS 
CORS_ORIGINS=["http://localhost:3000"]
