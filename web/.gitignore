# See https://help.github.com/articles/ignoring-files/

# ── Dependencies ──────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
!.yarn/sdks

# ── Testing ───────────────────────────────────────────────────────────────────
/coverage

# ── Next.js build output ─────────────────────────────────────────────────────
/.next/
/out/

# ── Production builds ────────────────────────────────────────────────────────
/build

# ── Environment variables ────────────────────────────────────────────────────
.env*
!.env.example

# ── Deployment ────────────────────────────────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Certificates / secrets ───────────────────────────────────────────────────
*.pem

# ── Package managers ─────────────────────────────────────────────────────────
.pnpm-store/


# ── ESLint cache ─────────────────────────────────────────────────────────────
.eslintcache